                @Html.TextBoxFor(model => model.JMBGu, new { @readonly = "true", @Value = Model.JMBGu, @class = "form-control narrow" })
                @Html.ValidationMessageFor(model => model.JMBGu, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Ime, htmlAttributes: new { @class = "control-label col-md-2" })
