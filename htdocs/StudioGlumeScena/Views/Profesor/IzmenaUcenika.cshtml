@model StudioGlumeScena.Models.Ucenik

@{
    ViewBag.Title = "Izmena ucenika";
}

<h1><b>Izmena učenika</b></h1>
<hr style="border-top: 1px solid #E2C044" />
@using (Html.BeginForm())
